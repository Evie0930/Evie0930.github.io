# Supabase Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (Vercel deployment URL, no trailing slash)
# Example: https://my-website-api.vercel.app
# Leave empty to use Vite dev proxy (local development)
VITE_API_BASE_URL=
